/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "../../out-tsc/app",
    "types": [],
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "paths": {
      "@shared": ["../shared/src/public-api.ts"],
      "@ui": ["../ui/src/public-api.ts"],
      "@env": ["../environment/index.ts"],
      "@auth/*": ["../auth/src/*"],
      "@todo/*": ["../todo/src/*"],
      "@history/*": ["./src/*"]
    }
  },
  "references": [{ "path": "../shared/tsconfig.lib.json" }, { "path": "../ui/tsconfig.lib.json" }],
  "include": ["src/**/*.ts", "../environment"],
  "exclude": ["src/**/*.spec.ts"]
}
