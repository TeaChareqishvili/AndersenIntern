{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "../../out-tsc/app",
    "types": [],
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "rootDir": "../../",
    "paths": {
      "@shared": ["../shared/src/public-api.ts"],
      "@ui": ["../ui/src/public-api.ts"],
      "@env": ["../environment/index.ts"],
      "@auth/*": ["../auth/src/*"],
      "@todo/*": ["./src/*"]
    }
  },
  "references": [
    { "path": "../shared/tsconfig.lib.json" },
    { "path": "../ui/tsconfig.lib.json" }
  ],
  "include": ["src/**/*.ts", "../environment"],
  "exclude": ["src/**/*.spec.ts"]
}
